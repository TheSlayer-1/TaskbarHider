<Window x:Class="TaskbarHider.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:tb="http://www.hardcodet.net/taskbar"
        Title="TaskbarHider" Height="100" Width="300"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False"
        Visibility="Hidden">
    <Grid Background="#F0F0F0">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="TaskbarHider is running..." FontSize="14" Foreground="#333"/>
            <TextBlock Text="Right-click the system tray icon to access settings." FontSize="11" Foreground="#666" Margin="0,5,0,0"/>
        </StackPanel>

        <!-- System Tray Icon -->
        <tb:TaskbarIcon x:Name="MyNotifyIcon"
                        IconSource="pack://application:,,,/Resources/icon.ico"
                        ToolTipText="TaskbarHider - Auto-hide taskbar">
            <tb:TaskbarIcon.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Settings" Click="OpenSettings_Click"/>
                    <Separator/>
                    <MenuItem Header="Exit" Click="Exit_Click"/>
                </ContextMenu>
            </tb:TaskbarIcon.ContextMenu>
        </tb:TaskbarIcon>
    </Grid>
</Window>